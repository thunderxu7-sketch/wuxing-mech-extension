{
  "manifest_version": 3,
  "name": "五行校准 (WuXing Calibrate)",
  "version": "1.0.0",
  "description": "算法驱动的每日能量校准。",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon48.png",
    "default_title": "五行校准"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "host_permissions": []
}
